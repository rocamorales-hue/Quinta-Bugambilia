<!DOCTYPE html>
<html lang="es">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0, viewport-fit=cover">
  <title>Quinta Bugambilia – Contrato de Evento con Hospedaje</title>
  <link href="https://fonts.googleapis.com/css2?family=Cormorant+Garamond:wght@300;400;600&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <style>
    /* ==========================================================================
       RESET & VARIABLES GLOBALES
       ========================================================================== */
    *, *::before, *::after { 
      box-sizing: border-box; 
      margin: 0; 
      padding: 0; 
    }

    :root {
      --sand: #ddeef7; 
      --cream: #f2f9f4; 
      --charcoal: #1e3a2f; 
      --warm: #4a7fa5;
      --gold: #5db87a; 
      --green: #3a8f5e; 
      --red: #b94040; 
      --amber: #4a7fa5;
      --green-bg: #e8f5ee; 
      --red-bg: #faeaea; 
      --amber-bg: #ddeef7; 
      --border: #b8d9c8;
    }

    body { 
      font-family: 'DM Sans', sans-serif; 
      background: var(--cream); 
      color: var(--charcoal); 
      min-height: 100vh; 
      overflow-x: hidden; 
    }

    /* ==========================================================================
       HEADER & NAVIGATION
       ========================================================================== */
    header { 
      background: rgba(30, 58, 47, 0.95); 
      backdrop-filter: blur(12px); 
      -webkit-backdrop-filter: blur(12px);
      color: #fff; 
      padding: 1rem; 
      display: flex; 
      flex-direction: column; 
      align-items: center; 
      gap: 0.8rem;
      position: sticky; 
      top: 0; 
      z-index: 100; 
      box-shadow: 0 4px 20px rgba(0, 0, 0, 0.15);
      border-bottom: 1px solid rgba(255, 255, 255, 0.08);
    }

    .logo { 
      font-family: 'Cormorant Garamond', serif; 
      font-size: 1.4rem; 
      font-weight: 400; 
      letter-spacing: .05em; 
      text-align: center;
    }
    .logo span { 
      color: var(--gold); 
      opacity: 0.9; 
      font-size: 0.8rem; 
      font-family: 'DM Sans', sans-serif;
      margin-left: 0.3rem;
      font-weight: 300;
    }
    
    .nav-container { 
      display: grid;
      grid-template-columns: repeat(2, 1fr);
      gap: 0.4rem; 
      width: 100%; 
    }

    .nav-link, .action-btn { 
      background: rgba(255, 255, 255, 0.05); 
      border: 1px solid rgba(255, 255, 255, 0.1); 
      color: #fff; 
      padding: 0.65rem 0.5rem; 
      border-radius: 10px; 
      font-size: 0.8rem; 
      font-weight: 500;
      cursor: pointer; 
      display: flex; 
      align-items: center; 
      justify-content: center; 
      gap: 0.4rem; 
      text-decoration: none; 
      transition: all 0.2s ease-in-out; 
      -webkit-tap-highlight-color: transparent; 
      font-family: 'DM Sans', sans-serif;
    }

    .nav-link:active, .nav-link:hover, .action-btn:active, .action-btn:hover { 
      background: rgba(255, 255, 255, 0.15); 
      border-color: rgba(255, 255, 255, 0.25);
    }

    /* ==========================================================================
       MAIN CONTENT & FORM SYSTEM
       ========================================================================== */
    main { max-width: 800px; margin: 0 auto; padding: 1rem 0.5rem 3rem; }
    h1 { font-family: 'Cormorant Garamond', serif; font-size: 1.8rem; font-weight: 300; margin-bottom: .2rem; text-align: center; }
    .subtitle { color: var(--warm); font-size: .8rem; margin-bottom: 1.5rem; text-align: center; }

    .form-container { 
      background: #fff; 
      padding: 1.2rem; 
      border-radius: 12px; 
      border: 1px solid var(--border); 
      box-shadow: 0 4px 16px rgba(0,0,0,.04);
      margin-bottom: 1.5rem;
    }

    .field { display: flex; flex-direction: column; margin-bottom: 1rem; }
    .row { display: grid; grid-template-columns: 1fr 1fr; gap: 0.5rem; margin-bottom: 0; }
    
    label { 
      display: block; 
      font-size: .7rem; 
      font-weight: 600; 
      text-transform: uppercase; 
      letter-spacing: .05em; 
      color: var(--warm); 
      margin-bottom: 0.3rem; 
    }

    input[type="text"], input[type="date"], input[type="time"], textarea, select {
      width: 100%; 
      padding: 0.65rem 0.8rem; 
      font-family: 'DM Sans', sans-serif; 
      font-size: 0.9rem; 
      color: var(--charcoal); 
      background: var(--cream); 
      border: 1px solid var(--border); 
      border-radius: 8px; 
      outline: none;
      transition: all 0.2s;
      box-sizing: border-box;
    }
    input:focus, textarea:focus, select:focus { border-color: var(--warm); background: #fff; box-shadow: 0 0 0 3px rgba(74,127,165,0.1); }
    textarea { resize: vertical; min-height: 70px; }
    input[readonly] { background: #f0f0f0 !important; cursor: not-allowed; }

    .extras-container {
      background: #f9fdfb; 
      padding: 0.3rem; 
      border-radius: 10px; 
      border: 1px solid var(--border); 
      margin-bottom: 1rem;
    }
    .extra-item { 
      display: flex; align-items: center; padding: 0.75rem; border-bottom: 1px solid #eee; cursor: pointer; -webkit-tap-highlight-color: transparent;
    }
    .extra-item:last-child { border-bottom: none; }
    .extra-item input[type="checkbox"] { 
      width: 22px; height: 22px; margin-right: 12px; flex-shrink: 0; 
      accent-color: var(--green); cursor: pointer;
    }
    .extra-label { flex-grow: 1; font-size: 0.85rem; }
    .extra-price { font-weight: 600; color: var(--green); font-size: 0.85rem; }

    .manual-extra {
      display: grid; grid-template-columns: 1fr 100px; gap: 0.5rem;
      padding: 0.6rem; background: #fff; border-top: 1px solid #eee;
    }

    .btn-generar {
      width: 100%; padding: 0.8rem; background: var(--charcoal); color: white; 
      border: none; border-radius: 8px; cursor: pointer; font-family: 'DM Sans', sans-serif; font-weight: 500; font-size: 0.9rem;
      margin-top: 10px; display: flex; align-items: center; justify-content: center; gap: 0.5rem;
      transition: background 0.2s; -webkit-tap-highlight-color: transparent;
    }
    .btn-generar:active { background: #2c5444; }

    /* ==========================================================================
       CONTRATO VISTA PREVIA (Estilo Documental Oficial)
       ========================================================================== */
    #contrato-final { 
      display: none; 
      background: #fff; 
      padding: 1.5rem; 
      border-radius: 12px; 
      border: 1px solid var(--border); 
      box-shadow: 0 4px 20px rgba(0,0,0,.06);
      line-height: 1.6;
      font-size: 0.85rem;
      text-align: justify;
      color: #000;
      animation: fadeUp 0.4s ease-out;
    }
    @keyframes fadeUp { from { opacity: 0; transform: translateY(10px); } to { opacity: 1; transform: none; } }

    .header-contrato { text-align: center; margin-bottom: 1.5rem; border-bottom: 2px solid var(--charcoal); padding-bottom: 0.8rem; }
    .header-contrato h2 { font-family: 'Cormorant Garamond', serif; font-size: 1.3rem; font-weight: 600; text-transform: uppercase; color: var(--charcoal); margin: 0; text-decoration: underline; }
    
    .clausula-title { font-weight: bold; text-decoration: underline; display: inline; color: #000; }
    #contrato-final p { margin-bottom: 0.8rem; color: #111; }
    
    .seccion-detalles { margin-top: 1rem; padding: 1rem; border: 1px dashed var(--border); background: var(--cream); border-radius: 8px; }
    .reglas-oro { border: 2px solid var(--charcoal); padding: 1rem; margin-top: 1.5rem; background: #fff; border-radius: 8px; }

    .tabla-banco { width: 100%; border-collapse: collapse; margin: 1rem 0; font-size: 0.8rem; }
    .tabla-banco td { padding: 0.4rem 0.6rem; border: 1px solid #ccc; }
    .tabla-banco td:first-child { font-weight: bold; background-color: #f5f5f5; width: 30%; }

    .firmas-container { display: grid; grid-template-columns: 1fr; gap: 2rem; margin-top: 2.5rem; text-align: center; }
    .firmas-box { margin-top: 1rem; }
    .linea-firma { width: 70%; height: 1px; background: #000; margin: 0 auto 0.4rem; padding-top: 5px; border-top: 1px solid #000; }

    .no-print-area { display: flex; justify-content: center; margin-top: 1.5rem; }
    .btn-print { background: var(--green); color: #fff; border: none; padding: 0.7rem 1.5rem; font-size: 0.85rem; font-weight: 500; border-radius: 8px; cursor: pointer; display: flex; align-items: center; gap: 0.5rem; transition: background 0.2s; }
    .btn-print:active { background: #2e6f49; }

    /* ==========================================================================
       MEDIA QUERIES & CONTROL DE IMPRESIÓN
       ========================================================================== */
    @media(min-width: 768px) {
      header { flex-direction: row; justify-content: space-between; padding: 0 2rem; height: 65px; }
      .nav-container { display: flex; width: auto; gap: 0.5rem; }
      .logo { font-size: 1.6rem; }
      main { padding: 1.5rem 1rem 4rem; }
      h1 { font-size: 2.2rem; }
      .subtitle { font-size: .88rem; }
      .form-container { padding: 2rem; }
      #contrato-final { padding: 3rem; font-size: 0.95rem; }
      .header-contrato h2 { font-size: 1.5rem; }
      .firmas-container { grid-template-columns: 1fr 1fr; gap: 3rem; }
    }

    @media print {
      body, main { background: #fff; padding: 0; margin: 0; color: #000; }
      header, .form-container, h1, .subtitle, .no-print-area, footer { display: none !important; }
      #contrato-final { display: block !important; border: none !important; box-shadow: none !important; padding: 0 !important; margin: 0 !important; width: 100%; }
      .firmas-print-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 20px; margin-top: 50px; }
      .firmas-box { margin-bottom: 0; }
      @page { margin: 1.2cm; }
    }
  </style>
</head>
<body>

  <header>
    <div class="logo">Quinta Bugambilia <span>· Real del 14</span></div>
    <div class="nav-container">
      <button class="action-btn" onclick="clearForm()">
        <svg style="width:14px;height:14px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M23 4v6h-6M1 20v-6h6"/><path d="M3.51 9a9 9 0 0114.85-3.36L23 10"/></svg>
        <span>Nuevo Contrato</span>
      </button>
    </div>
  </header>

  <main>
    <h1>Contrato de Evento con Hospedaje</h1>
    <p class="subtitle">Panel integral de control de reservas, cotización y hospedaje</p>

    <div class="form-container">
      <div class="row">
        <div class="field">
          <label>Nombre del Cliente Arrendatario</label>
          <input type="text" id="nombreInput" placeholder="Ej. Roberto Morales">
        </div>
        <div class="field">
          <label>Identificación Oficial (INE / Pasaporte)</label>
          <input type="text" id="ineInput" placeholder="Clave de Elector o No. de Documento">
        </div>
      </div>

      <div class="row">
        <div class="field">
          <label>Fecha de Entrada (Check-In)</label>
          <input type="date" id="fechaEntrada" onchange="calcularTotal()">
        </div>
        <div class="field">
          <label>Hora de Entrada</label>
          <input type="time" id="horaEntrada" value="15:00">
        </div>
      </div>

      <div class="row">
        <div class="field">
          <label>Fecha de Salida (Check-Out)</label>
          <input type="date" id="fechaSalida" onchange="calcularTotal()">
        </div>
        <div class="field">
          <label>Hora de Salida</label>
          <input type="time" id="horaSalida" value="12:00">
        </div>
      </div>

      <div class="field">
        <label>Paquete de Evento (Base de Personas)</label>
        <select id="paqueteSelect" onchange="calcularTotal()">
          <option value="0" data-price="0">Seleccionar Paquete</option>
          <option value="20" data-price="4600">20 personas — $4,600</option>
          <option value="30" data-price="6540">30 personas — $6,540</option>
          <option value="40" data-price="8240">40 personas — $8,240</option>
          <option value="50" data-price="9700">50 personas — $9,700</option>
          <option value="60" data-price="10420">60 personas — $10,420</option>
          <option value="70" data-price="11140">70 personas — $11,140</option>
          <option value="80" data-price="11860">80 personas — $11,860</option>
          <option value="Hospedaje Puro / Personalizado" data-price="0">Solo Hospedaje / Precio Manual</option>
        </select>
      </div>

      <label>Servicios Extra / Adicionales</label>
      <div class="extras-container">
        <div class="extra-item" onclick="toggleCheckbox('extraBrincolin')">
          <input type="checkbox" id="extraBrincolin" value="500" onchange="calcularTotal()">
          <span class="extra-label">Brincolin Estándar</span>
          <span class="extra-price">+$500</span>
        </div>
        <div class="extra-item" onclick="toggleCheckbox('extraBrincolinAcuatico')">
          <input type="checkbox" id="extraBrincolinAcuatico" value="1200" onchange="calcularTotal()">
          <span class="extra-label">Brincolin Acuático Grande</span>
          <span class="extra-price">+$1,200</span>
        </div>
        <div class="extra-item" onclick="toggleCheckbox('extraFutbolito')">
          <input type="checkbox" id="extraFutbolito" value="400" onchange="calcularTotal()">
          <span class="extra-label">Mesa de Futbolito</span>
          <span class="extra-price">+$400</span>
        </div>
        <div class="extra-item" onclick="toggleCheckbox('extraBocina')">
          <input type="checkbox" id="extraBocina" value="400" onchange="calcularTotal()">
          <span class="extra-label">Bocina de Alta Potencia</span>
          <span class="extra-price">+$400</span>
        </div>
        <div class="extra-item" onclick="toggleCheckbox('extraCalentador')">
          <input type="checkbox" id="extraCalentador" value="600" onchange="calcularTotal()">
          <span class="extra-label">Calentador Ambiental de Gas</span>
          <span class="extra-price">+$600</span>
        </div>

        <div class="manual-extra">
          <input type="text" id="manualNombre1" placeholder="Concepto Extra Manual (Ej. Sillas Extra)">
          <input type="text" id="manualMonto1" placeholder="$0.00" oninput="calcularTotal()">
        </div>
      </div>

      <div class="row">
        <div class="field">
          <label>Precio Total del Evento + Hospedaje ($)</label>
          <input type="text" id="precioInput" placeholder="Calculado automáticamente o ingresa valor manual">
        </div>
        <div class="field">
          <label>Anticipo de Reservación ($)</label>
          <input type="text" id="anticipoInput" placeholder="Monto abonado">
        </div>
      </div>

      <div class="row">
        <div class="field">
          <label>Depósito en Garantía (Reembolsable)</label>
          <input type="text" id="depositoInput" value="$1,500.00">
        </div>
        <div class="field">
          <label>Fecha de Firma de Contrato</label>
          <input type="date" id="fechaContrato">
        </div>
      </div>

      <div class="field">
        <label>Anotaciones Especiales / Acuerdos Específicos</label>
        <textarea id="anotacionesInput" placeholder="Ej. Se autoriza la entrada de proveedor de banquetes a las 11:00 AM..."></textarea>
      </div>

      <button class="btn-generar" onclick="generarContrato()">
        <svg style="width:18px;height:18px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"/><polyline points="14 2 14 8 20 8"/></svg>
        Generar e Integrar Contrato Final
      </button>
    </div>

    <div id="contrato-final">
      <div class="header-contrato">
        <h2>CONTRATO DE ARRENDAMIENTO DE EVENTO Y HOSPEDAJE</h2>
        <p style="font-size:0.75rem; margin-top:4px; letter-spacing:1px; color:#555;">QUINTA BUGAMBILIA – REAL DEL 14</p>
      </div>

      <p>Con fecha del <span id="out-fecha-contrato" style="font-weight:bold;"></span>, se celebra el presente contrato de arrendamiento para la realización de un evento social con servicio de hospedaje en las instalaciones de <strong>Quinta Bugambilia</strong>, ubicada en Real del 14, Hermosillo, Sonora, conviniendo las partes lo establecido en las siguientes cláusulas:</p>

      <p><span class="clausula-title">PRIMERA (Las Partes y Objeto):</span> El presente contrato es celebrado por la administración de Quinta Bugambilia (en adelante "El Arrendador") y el/la C. <span id="out-nombre" style="font-weight:bold; text-decoration:underline;"></span> identificado con documento oficial No. <span id="out-ine" style="font-weight:bold;"></span> (en adelante "El Arrendatario"). El Arrendador cede el uso temporal y exclusivo de las instalaciones exteriores para eventos, alberca, así como las habitaciones de descanso asignadas en la propiedad.</p>

      <p><span class="clausula-title">SEGUNDA (Vigencia, Horarios y Tolerancia):</span> La estancia pactada comprende el ingreso (Check-In) el día <span id="out-fecha-entrada" style="font-weight:bold;"></span> a las <span id="out-hora-entrada" style="font-weight:bold;"></span> horas, y la salida (Check-Out) definitiva del inmueble el día <span id="out-fecha-salida" style="font-weight:bold;"></span> a las <span id="out-hora-salida" style="font-weight:bold;"></span> horas. Se acuerda un periodo de tolerancia máximo de 30 minutos para la entrega física de la propiedad; transcurrido dicho tiempo, se aplicará una penalización automática de $300.00 MXN por cada media hora de retraso, deducible del depósito de garantía.</p>

      <p><span class="clausula-title">TERCERA (Precios, Anticipos y Liquidación):</span> El precio total estipulado por el paquete de evento y alojamiento es de <span id="out-precio" style="font-weight:bold; color:var(--green);"></span>. El Arrendatario otorga en este acto un anticipo de <span id="out-anticipo" style="font-weight:bold;"></span>. El saldo restante deberá ser liquidado sin excepción en un plazo máximo de <strong>15 días antes</strong> de la fecha de ingreso. De no liquidarse en dicho periodo, El Arrendador se reserva el derecho de cancelar el evento sin devolución del anticipo.</p>

      <p><span class="clausula-title">CUARTA (Depósito en Garantía):</span> Adicional al costo del servicio, El Arrendatario entrega la cantidad de <span id="out-deposito" style="font-weight:bold;"></span> en concepto de depósito para responder por posibles daños al mobiliario, áreas verdes, habitaciones, toallas o equipos de la Quinta, así como para cubrir penalizaciones de horario. Este monto será devuelto íntegramente en las 48 horas posteriores al evento tras la verificación física satisfactoria del inmueble.</p>

      <p><span class="clausula-title">QUINTA (Capacidad y Paquete Contratado):</span> El evento se contrata bajo la modalidad de base para <span id="out-paquete" style="font-weight:bold;"></span> personas. El cupo de personas pernoctando en las habitaciones de hospedaje respetará el límite de diseño de las camas provistas. El exceso no autorizado de personas en el área de evento o habitaciones facultará al Arrendador a rescindir el contrato o cobrar cargos adicionales equivalentes.</p>

      <div class="seccion-detalles">
        <strong>SERVICIOS ADICIONALES INCLUIDOS Y ACUERDOS ESPECÍFICOS:</strong>
        <p id="out-detalles-extras" style="margin-top: 5px; font-style: italic; white-space: pre-line;"></p>
      </div>

      <p><span class="clausula-title">SEXTA (Normativa Interna y Convivencia):</span> El Arrendatario se compromete a respetar y hacer cumplir a sus invitados el reglamento interno de Quinta Bugambilia, el cual incluye:</p>
      <div class="reglas-oro">
        <strong>REGLAS CRÍTICAS DE QUINTA BUGAMBILIA:</strong>
        <ol style="margin-left:1.5rem; margin-top:5px; font-size:0.8rem; line-height:1.5;">
          <li>El volumen de la música deberá moderarse estrictamente a los decibeles autorizados por las normativas de la localidad, prohibiéndose música de alta intensidad fuera de los horarios establecidos.</li>
          <li>Está estrictamente prohibido introducir envases de vidrio, alimentos u objetos punzocortantes al interior de la alberca.</li>
          <li>Cuidado de Habitaciones: No se permite ingresar a los dormitorios con ropa húmeda o trajes de baño mojados. Queda prohibido fumar dentro de las habitaciones.</li>
          <li>La limpieza básica de la basura generada durante el evento debe ser depositada en los contenedores designados antes del Check-Out.</li>
        </ol>
      </div>

      <p><span class="clausula-title">SÉPTIMA (Deslinde de Responsabilidad):</span> El Arrendador no se hace responsable por accidentes, lesiones o pérdidas materiales sufridas por El Arrendatario o sus invitados dentro de las instalaciones (incluyendo alberca y áreas recreativas), siendo total responsabilidad del firmante la supervisión de menores de edad y adultos.</p>

      <table class="tabla-banco">
        <tr>
          <td>Cuenta de Depósito / Transferencia:</td>
          <td>Banco: BBVA<br>Cuenta: 159 660 7623<br>CLABE: 012 760 01596607623 8<br>Titular: Roberto Carlos Morales Mizquez</td>
        </tr>
      </table>

      <div class="firmas-container firmas-print-grid">
        <div class="firmas-box">
          <div class="linea-firma"></div>
          <p style="font-size:0.75rem; font-weight:bold;">EL ARRENDATARIO (CLIENTE)</p>
          <p style="font-size:0.7rem; color:#444;" id="out-firma-nombre"></p>
        </div>
        <div class="firmas-box">
          <div class="linea-firma"></div>
          <p style="font-size:0.75rem; font-weight:bold;">EL ARRENDADOR</p>
          <p style="font-size:0.7rem; color:#444;">Administración Quinta Bugambilia</p>
        </div>
      </div>

      <div class="no-print-area">
        <button class="btn-print" onclick="window.print()">
          <svg style="width:16px;height:16px" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="6 9 6 2 18 2 18 9"/><path d="M6 18H4a2 2 0 0 1-2-2v-5a2 2 0 0 1 2-2h16a2 2 0 0 1 2 2v5a2 2 0 0 1-2 2h-2"/><rect x="6" y="14" width="12" height="8"/></svg>
          Imprimir Contrato Oficial
        </button>
      </div>
    </div>
  </main>

  <script>
    // Set inicial de la fecha del contrato al día de hoy automáticamente
    document.addEventListener("DOMContentLoaded", function() {
      const hoy = new Date().toISOString().split('T')[0];
      document.getElementById('fechaContrato').value = hoy;
    });

    // Control de selección nativa táctil en el div contenedor del checkbox
    function toggleCheckbox(id) {
      const cb = document.getElementById(id);
      if (event.target.tagName !== 'INPUT') {
        cb.checked = !cb.checked;
      }
      calcularTotal();
    }

    // Algoritmo dinámico de cálculo y formateo de cotizaciones
    function calcularTotal() {
      const selectPaquete = document.getElementById('paqueteSelect');
      const optionSeleccionada = selectPaquete.options[selectPaquete.selectedIndex];
      
      // Obtener precio base del paquete seleccionado
      let total = parseFloat(optionSeleccionada.getAttribute('data-price')) || 0;

      // Sumar Checkboxes de Extras
      const extrasIds = ['extraBrincolin', 'extraBrincolinAcuatico', 'extraFutbolito', 'extraBocina', 'extraCalentador'];
      extrasIds.forEach(id => {
        const item = document.getElementById(id);
        if (item && item.checked) {
          total += parseFloat(item.value);
        }
      });

      // Sumar Extra Manual si cuenta con valor numérico correcto
      const manualMonto = document.getElementById('manualMonto1').value.replace(/[^0-9.]/g, '');
      if (manualMonto !== "" && !isNaN(manualMonto)) {
        total += parseFloat(manualMonto);
      }

      // Inyectar el resultado formateado en el Input de costo si no es paquete manual libre
      if(optionSeleccionada.value !== "Hospedaje Puro / Personalizado" || total > 0) {
        document.getElementById('precioInput').value = formatCurrency(total);
      }
    }

    // Helper de parseo de moneda estándar
    function formatCurrency(val) {
      return '$' + val.toFixed(2).replace(/\d(?=(\d{3})+\.)/g, '$&,');
    }

    // Helper de conversión de formato de fecha ISO a legible en español
    function stringToFullDate(dateString) {
      if(!dateString) return "";
      const parts = dateString.split('-');
      const date = new Date(parts[0], parts[1] - 1, parts[2]);
      const opciones = { year: 'numeric', month: 'long', day: 'numeric' };
      return date.toLocaleDateString("es-MX", opciones);
    }

    // Despliegue de contrato y parsing de variables del DOM
    function generarContrato() {
      // Validaciones básicas de sanidad de datos
      const nombre = document.getElementById('nombreInput').value.trim();
      if(nombre === "") {
        alert("Por favor ingrese el Nombre del Cliente Arrendatario.");
        return;
      }

      // Binding de Inputs a la sección imprimible del contrato
      document.getElementById('out-nombre').innerText = nombre;
      document.getElementById('out-firma-nombre').innerText = nombre;
      document.getElementById('out-ine').innerText = document.getElementById('ineInput').value || "_________________";
      
      // Parseo de Fechas
      document.getElementById('out-fecha-contrato').innerText = stringToFullDate(document.getElementById('fechaContrato').value);
      document.getElementById('out-fecha-entrada').innerText = stringToFullDate(document.getElementById('fechaEntrada').value);
      document.getElementById('out-fecha-salida').innerText = stringToFullDate(document.getElementById('fechaSalida').value);
      
      // Horas
      document.getElementById('out-hora-entrada').innerText = document.getElementById('horaEntrada').value;
      document.getElementById('out-hora-salida').innerText = document.getElementById('horaSalida').value;

      // Costos e importes financieros
      document.getElementById('out-precio').innerText = document.getElementById('precioInput').value || "$0.00";
      document.getElementById('out-anticipo').innerText = document.getElementById('anticipoInput').value ? '$' + document.getElementById('anticipoInput').value.replace(/[^0-9.]/g, '') : "$0.00";
      document.getElementById('out-deposito').innerText = document.getElementById('depositoInput').value || "$1,500.00";

      // Resolver paquete e invitados
      const selectP = document.getElementById('paqueteSelect');
      const paqueteTexto = selectP.options[selectP.selectedIndex].value;
      document.getElementById('out-paquete').innerText = paqueteTexto === "0" ? "___" : paqueteTexto;

      // Compilación de Texto de Extras para la Cláusula Quinta
      let stringExtras = "";
      const extrasList = [
        {id: 'extraBrincolin', nombre: 'Brincolin Estándar'},
        {id: 'extraBrincolinAcuatico', nombre: 'Brincolin Acuático Grande'},
        {id: 'extraFutbolito', nombre: 'Mesa de Futbolito'},
        {id: 'extraBocina', nombre: 'Bocina de Alta Potencia'},
        {id: 'extraCalentador', nombre: 'Calentador Ambiental de Gas'}
      ];

      extrasList.forEach(item => {
        if(document.getElementById(item.id).checked) {
          stringExtras += `• Incluye servicio de: ${item.nombre}.\n`;
        }
      });

      const manualNombre = document.getElementById('manualNombre1').value.trim();
      const manualPrecio = document.getElementById('manualMonto1').value.trim();
      if(manualNombre !== "") {
        stringExtras += `• Extra Personalizado: ${manualNombre} (${manualPrecio}).\n`;
      }

      const anotaciones = document.getElementById('anotacionesInput').value.trim();
      if(anotaciones !== "") {
        stringExtras += `\nNotas de la Administración: ${anotaciones}`;
      }

      if(stringExtras === "") {
        stringExtras = "Ninguno. Solo se compromete el paquete base configurado.";
      }
      document.getElementById('out-detalles-extras').innerText = stringExtras;

      // Control de flujo UI/UX: Mostrar contrato y smooth scroll automático
      const boxContrato = document.getElementById('contrato-final');
      boxContrato.style.display = 'block';
      setTimeout(() => {
        boxContrato.scrollIntoView({ behavior: 'smooth', block: 'start' });
      }, 150);
    }

    // Reseteo total del formulario de captura para nuevas operaciones
    function clearForm() {
      document.getElementById('nombreInput').value = "";
      document.getElementById('ineInput').value = "";
      document.getElementById('fechaEntrada').value = "";
      document.getElementById('fechaSalida').value = "";
      document.getElementById('horaEntrada').value = "15:00";
      document.getElementById('horaSalida').value = "12:00";
      document.getElementById('paqueteSelect').value = "0";
      document.getElementById('precioInput').value = "";
      document.getElementById('anticipoInput').value = "";
      document.getElementById('manualNombre1').value = "";
      document.getElementById('manualMonto1').value = "";
      document.getElementById('anotacionesInput').value = "";
      document.getElementById('depositoInput').value = "$1,500.00";
      
      const hoy = new Date().toISOString().split('T')[0];
      document.getElementById('fechaContrato').value = hoy;

      // Desmarcar todos los checkboxes
      const checkboxes = document.querySelectorAll('.extra-item input[type="checkbox"]');
      checkboxes.forEach(cb => cb.checked = false);

      // Ocultar vista previa
      document.getElementById('contrato-final').style.display = 'none';
      window.scrollTo({ top: 0, behavior: 'smooth' });
    }
  </script>
</body>
</html>
